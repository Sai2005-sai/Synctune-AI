ackage</w:t></w:r></w:p><w:p w14:paraId="570A238E" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:r><w:t>Inside the frontend project:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>npm install gh-pages --save-dev</w:t></w:r></w:p><w:p w14:paraId="3B02D714" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:sz w:val="28"/></w:rPr><w:t>Step 3 — Update package.json</w:t></w:r></w:p><w:p w14:paraId="7701E198" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:r><w:t>Open package.json.</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>Add homepage:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>"homepage": "https://YOUR_USERNAME.github.io/YOUR_REPO",</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>Inside "scripts" add:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>"predeploy": "npm run build",</w:t></w:r><w:r><w:br/><w:t>"deploy": "gh-pages -d build"</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>Example:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>"scripts": {</w:t></w:r><w:r><w:br/><w:t xml:space="preserve">  "start": "react-scripts start",</w:t></w:r><w:r><w:br/></w:r><w:r><w:lastRenderedPageBreak/><w:t xml:space="preserve">  "build": "react-scripts build",</w:t></w:r><w:r><w:br/><w:t xml:space="preserve">  "predeploy": "npm run build",</w:t></w:r><w:r><w:br/><w:t xml:space="preserve">  "deploy": "gh-pages -d build"</w:t></w:r><w:r><w:br/><w:t>}</w:t></w:r></w:p><w:p w14:paraId="1E38816D" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:sz w:val="28"/></w:rPr><w:t>Step 4 — Deploy React Project to GitHub Pages</w:t></w:r></w:p><w:p w14:paraId="78C9FA27" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:r><w:t>Inside the frontend project folder run:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>npm run deploy</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>This command:</w:t></w:r><w:r><w:br/><w:t>• Builds the React application</w:t></w:r><w:r><w:br/><w:t>• Creates a production build</w:t></w:r><w:r><w:br/><w:t>• Uploads the build to GitHub Pages</w:t></w:r></w:p><w:p w14:paraId="778E95E9" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:sz w:val="28"/></w:rPr><w:t>Step 5 — Enable GitHub Pages</w:t></w:r></w:p><w:p w14:paraId="341A13A4" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:r><w:t>1. Open your GitHub repository</w:t></w:r><w:r><w:br/><w:t>2. Go to:</w:t></w:r><w:r><w:br/><w:t xml:space="preserve">   Settings → Pages</w:t></w:r><w:r><w:br/><w:t>3. Under:</w:t></w:r><w:r><w:br/><w:t xml:space="preserve">   Build and deployment</w:t></w:r><w:r><w:br/><w:t>4. Select:</w:t></w:r><w:r><w:br/><w:t xml:space="preserve">   Source → Deploy from branch</w:t></w:r><w:r><w:br/><w:t>5. Choose:</w:t></w:r><w:r><w:br/><w:t xml:space="preserve">   Branch → gh-pages</w:t></w:r><w:r><w:br/><w:t>6. Click:</w:t></w:r><w:r><w:br/><w:t xml:space="preserve">   Save</w:t></w:r></w:p><w:p w14:paraId="67704820" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:sz w:val="28"/></w:rPr><w:t>Step 6 — Access the Live Application</w:t></w:r></w:p><w:p w14:paraId="598BF3C0" w14:textId="162E7D32" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:r><w:t>After deployment, GitHub provides a live URL:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>https://YOUR_USERNAME.github.io/YOUR_REPO</w:t></w:r><w:r><w:br/></w:r></w:p><w:p w14:paraId="6912FDD1" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:sz w:val="28"/></w:rPr><w:t>Step 7 — Configure React Router for GitHub Pages</w:t></w:r></w:p><w:p w14:paraId="18A01870" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:r><w:t>Replace:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>import { BrowserRouter } from 'react-router-dom';</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>With:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>import { HashRouter } from 'react-router-dom';</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/></w:r><w:r><w:lastRenderedPageBreak/><w:t>Then update:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>&lt;BrowserRouter&gt;</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>To:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>&lt;HashRouter&gt;</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>This prevents:</w:t></w:r><w:r><w:br/><w:t>404 Page Not Found</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>errors on page refresh or direct route access.</w:t></w:r></w:p><w:p w14:paraId="50D64E8A" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:sz w:val="28"/></w:rPr><w:t>Step 8 — Rebuild and Redeploy</w:t></w:r></w:p><w:p w14:paraId="488FD368" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:r><w:t>After router changes:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>npm run build</w:t></w:r><w:r><w:br/><w:t>npm run deploy</w:t></w:r></w:p><w:p w14:paraId="50AE1D5D" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:sz w:val="28"/></w:rPr><w:t>Step 9 — Verify Deployment</w:t></w:r></w:p><w:p w14:paraId="42A957CB" w14:textId="3466473C" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:r><w:t>Test:</w:t></w:r><w:r><w:br/><w:t>• Homepage loads</w:t></w:r><w:r><w:br/><w:t>• Login page works</w:t></w:r><w:r><w:br/><w:t>• Refresh works</w:t></w:r><w:r><w:br/><w:t>• Direct URL access works</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>Example:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>https://</w:t></w:r><w:r w:rsidR="003D152D"><w:t>USERNAME</w:t></w:r><w:r><w:t>.github.io/</w:t></w:r><w:r w:rsidR="003D152D"><w:t>REPO</w:t></w:r><w:r><w:t>/#/login</w:t></w:r></w:p><w:p w14:paraId="7599ECDF" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:sz w:val="28"/></w:rPr><w:t>Step 10 — Add Selenium E2E Testing</w:t></w:r></w:p><w:p w14:paraId="2D2116F5" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:r><w:t>Install Selenium dependencies:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>npm install selenium-webdriver mocha --save-dev</w:t></w:r></w:p><w:p w14:paraId="697A76DD" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:sz w:val="28"/></w:rPr><w:t>Step 11 — Create Selenium Test Structure</w:t></w:r></w:p><w:p w14:paraId="1A2EEF87" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:r><w:t>Recommended structure:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>frontend/</w:t></w:r><w:r><w:br/><w:t>│</w:t></w:r><w:r><w:br/><w:t>├── selenium-tests/</w:t></w:r><w:r><w:br/><w:t>│   ├── tests/</w:t></w:r><w:r><w:br/></w:r><w:r><w:lastRenderedPageBreak/><w:t>│   │   └── login.test.js</w:t></w:r><w:r><w:br/><w:t>│   ├── package.json</w:t></w:r></w:p><w:p w14:paraId="15A7CF75" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:sz w:val="28"/></w:rPr><w:t>Step 12 — Add Stable IDs for Automation</w:t></w:r></w:p><w:p w14:paraId="61CE84EF" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:r><w:t>Example:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>&lt;Input id="email" /&gt;</w:t></w:r><w:r><w:br/><w:t>&lt;Input id="password" /&gt;</w:t></w:r><w:r><w:br/><w:t>&lt;Button id="login-button" /&gt;</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>This allows Selenium to locate elements reliably.</w:t></w:r></w:p><w:p w14:paraId="4ACE9EF6" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:sz w:val="28"/></w:rPr><w:t>Step 13 — Run Selenium Test Locally</w:t></w:r></w:p><w:p w14:paraId="73B530E9" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:r><w:t>Run:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>npm run login</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>This:</w:t></w:r><w:r><w:br/><w:t>• Opens Chrome</w:t></w:r><w:r><w:br/><w:t>• Navigates to login page</w:t></w:r><w:r><w:br/><w:t>• Enters credentials</w:t></w:r><w:r><w:br/><w:t>• Validates dashboard redirect</w:t></w:r></w:p><w:p w14:paraId="092249EB" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:sz w:val="28"/></w:rPr><w:t>Step 14 — Setup GitHub Actions</w:t></w:r></w:p><w:p w14:paraId="037A65CF" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:r><w:t>Create:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>.github/workflows/selenium-login.yml</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>GitHub Actions automatically:</w:t></w:r><w:r><w:br/><w:t>• Installs dependencies</w:t></w:r><w:r><w:br/><w:t>• Runs Selenium tests</w:t></w:r><w:r><w:br/><w:t>• Reports pass/fail status</w:t></w:r></w:p><w:p w14:paraId="09A07AD6" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:sz w:val="28"/></w:rPr><w:t>Step 15 — Automatic CI/CD Testing</w:t></w:r></w:p><w:p w14:paraId="6C9525E7" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:r><w:t>Whenever code is pushed:</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>git push</w:t></w:r><w:r><w:br/></w:r><w:r><w:br/><w:t>GitHub Actions automatically triggers:</w:t></w:r><w:r><w:br/><w:t>• Build validation</w:t></w:r><w:r><w:br/><w:t>• Selenium E2E tests</w:t></w:r><w:r><w:br/><w:t>• Deployment verification</w:t></w:r></w:p><w:p w14:paraId="30DBF7AB" w14:textId="77777777" w:rsidR="0092522D" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr>