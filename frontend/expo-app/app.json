{
  "expo": {
    "name": "AI Video BGM Matcher",
    "slug": "aivideobgm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#08080F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aivideobgm.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to select videos for BGM matching.",
        "NSPhotoLibraryAddUsageDescription": "This app saves the exported video with background music to your photo library.",
        "NSMicrophoneUsageDescription": "This app requires microphone access for video processing."
      }
    },
    "android": {
      "package": "com.aivideobgm.app",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#08080F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AI Video BGM Matcher to access your photos and videos.",
          "cameraPermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow AI Video BGM Matcher to save exported videos to your photo library.",
          "savePhotosPermission": "Allow AI Video BGM Matcher to save exported videos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-sharing",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "9f18fb74-09f5-4376-b9fe-ac4aef862a58"
      }
    }
  }
}
